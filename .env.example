# Copy this file to .env and fill in real values. .env is gitignored.

# Groq (only remote dependency for the May 30 demo — free tier)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Local STT
WHISPER_MODEL=base

# Local embeddings
EMBEDDING_MODEL=all-mpnet-base-v2
EMBEDDING_DIM=768

# Vector store
CHROMA_DIR=./chroma_db
TOP_K=5
RETRIEVAL_CONFIDENCE_THRESHOLD=0.35

# Response shaping
RESPONSE_WORD_LIMIT=150

# Conversation window
CONVERSATION_WINDOW_MINUTES=5
TRIGGER_WORDS=that's enough,okay thank you,thank you,next question
